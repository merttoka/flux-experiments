{
  "redirects": [
    { "source": "/bfl-api", "destination": "/bfl-api/" }
  ],
  "rewrites": [
    { "source": "/bfl-api/api/(.*)", "destination": "/api/$1" },
    { "source": "/bfl-api/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/bfl-api/examples/(.*)", "destination": "/examples/$1" },
    { "source": "/bfl-api/(.*)", "destination": "/" }
  ]
}
